      {term:"Electric potential energy", definition:"Energy that charges have because of the electric forces between them.", category:"Energy"},
      {term:"Elastic potential energy", definition:"Energy stored in a material that has been deformed elastically.", category:"Energy"},
      {term:"Chemical potential energy", definition:"Energy related to the arrangement of electrons within the structure of atoms and molecules.", category:"Energy"},
      {term:"Nuclear potential energy", definition:"Energy related to the forces between particles in the centres, or nuclei, of atoms.", category:"Energy"},
      {term:"Kinetic energy", definition:"Energy of moving masses.", category:"Energy"},
      {term:"Thermal energy", definition:"The non-mechanical transfer of energy between two or more bodies at different temperatures, from hotter to colder.", category:"Energy"},
      {term:"Electrical energy", definition:"Energy delivered in a circuit by an electrical current.", category:"Energy"},
      {term:"Radiation energy", definition:"Energy transferred by electromagnetic waves.", category:"Energy"},
      {term:"Internal energy", definition:"Total potential energies and random kinetic energies of the particles in a substance.", category:"Energy"},
      {term:"Conservation laws", definition:"In isolated systems, some physical quantities remain constant under all circumstances, such as energy, mass, charge and momentum.", category:"Energy"},
      {term:"Dissipated or degraded energy", definition:"Energy that has spread into the surroundings and cannot be recovered to do useful work.", category:"Energy"},
      {term:"Sankey diagram", definition:"Diagram representing the flow of energy in a system.", category:"Energy"},
      {term:"Mechanical energy", definition:"Energy of a macroscopic object which can do useful work.", category:"Energy"},
      {term:"Order of magnitude", definition:"An approximate value rounded to the nearest power of ten.", category:"Measurement"},
      {term:"Uncertainty", definition:"The range above and below a stated value over which repeated measurements would be expected to occur. Uncertainty can be expressed in absolute, fractional or percentage terms.", category:"Measurement"},
      {term:"Accuracy", definition:"A measurement is accurate if it is close to the correct result. A series of measurements is accurate if their mean is close to the correct result.", category:"Measurement"},
      {term:"Error", definition:"When a measurement is not the same as the correct value.", category:"Measurement"},
      {term:"Systematic error", definition:"An error which is always either bigger or smaller than the correct value by the same amount, for example a zero-offset error.", category:"Measurement"},
      {term:"Zero offset error", definition:"A measuring instrument has a zero offset error if it records a non-zero reading when it should be zero.", category:"Measurement"},
      {term:"Precision", definition:"A measurement is precise if a similar result would be obtained when the measurement is repeated.", category:"Measurement"},
      {term:"Hydroelectric power", definition:"The generation of electrical power from falling water.", category:"Energy"},
      {term:"Lever", definition:"A simple machine consisting of a rigid bar and a pivot. Used to change the direction and magnitude of a force.", category:"Machines"},
      {term:"Pulley", definition:"A rotating wheel used to change the direction of a force. When two or more pulleys are combined, the system can reduce the force needed to do work.", category:"Machines"},
      {term:"Conservative force", definition:"A force whose action conserves mechanical energy. There is no energy dissipation.", category:"Energy"},
      {term:"Regenerative braking", definition:"Decelerating a vehicle by transferring kinetic energy into a form that can be used later, rather than dissipating the energy into the surroundings; for example, generating current to charge a battery.", category:"Energy"},
      {term:"Power, P", definition:"Energy transferred divided by time taken; for mechanical energies, work done divided by time taken.", category:"Energy"},
      {term:"Watt, W", definition:"Derived SI unit of power. 1 W = 1 J s⁻¹.", category:"Units"},
      {term:"Resistive force, F", definition:"Any force that opposes motion, for example friction, air resistance or drag.", category:"Forces"},
      {term:"Efficiency, η", definition:"Ratio of useful energy or power output to total energy or power input.", category:"Energy"},
      {term:"Energy density", definition:"Energy transferred from unit volume of fuel. SI unit: J m⁻³.", category:"Energy"},
      {term:"Specific energy", definition:"Amount of energy that can be transferred from unit mass of an energy source. SI unit: J kg⁻¹.", category:"Energy"},
      {term:"Dynamics", definition:"The science which explains the motion of objects.", category:"Rotational dynamics"},
      {term:"Rotate", definition:"To move around a central point or axis, usually inside the rotating object.", category:"Rotational dynamics"},
      {term:"Revolve", definition:"To move around a central point or axis, usually outside the revolving object.", category:"Rotational dynamics"},
      {term:"Rigid", definition:"Does not change shape.", category:"Rotational dynamics"},
      {term:"Extended object", definition:"An object that has dimensions; not a point.", category:"Rotational dynamics"},
      {term:"Axis of rotation", definition:"Line about which an object can rotate.", category:"Rotational dynamics"},
      {term:"Rotational dynamics", definition:"Branch of physics and engineering that deals with rotating objects.", category:"Rotational dynamics"},
      {term:"Analogy", definition:"Applying knowledge of one subject to another because of some similarities.", category:"General physics"}
    ];

    const extraTips = {
      "Speed, v":"Tip: speed is scalar; velocity is vector. Misconception: speed and velocity are not always interchangeable.",
      "Velocity, v":"Tip: always include direction when describing velocity.",
      "Acceleration, a":"Tip: acceleration can occur when speed changes, direction changes, or both.",
      "Distance":"Tip: distance has no direction, so it is scalar.",
      "Displacement, linear":"Tip: displacement needs a reference point and a direction.",
      "Scalars":"Examples: speed, distance, mass, energy, time.",
      "Vector":"Examples: velocity, displacement, force, acceleration, momentum.",
      "Gradient":"Tip: in physics, the gradient often represents a meaningful quantity, such as velocity on a displacement-time graph.",
      "Integration":"Tip: area under a velocity-time graph gives displacement.",
      "Free fall":"Misconception: free fall does not mean falling in air with air resistance; ideal free fall ignores air resistance.",
      "Weight, Fg":"Tip: mass is measured in kg; weight is a force measured in N.",
      "Mass":"Misconception: mass and weight are not the same quantity.",
      "Resultant force":"Tip: if resultant force is zero, acceleration is zero, but the object may still move at constant velocity.",
      "Balanced forces":"Misconception: balanced forces do not necessarily mean the object is at rest.",
      "Inertia":"Tip: greater mass means greater inertia.",
      "Momentum, p":"Tip: momentum is conserved in isolated systems.",
      "Impulse":"Tip: impulse is also equal to change in momentum.",
      "Centripetal force":"Misconception: this is not a new type of force; it is the resultant force towards the centre.",
      "Work, W":"Tip: only the component of force in the direction of displacement does work.",
      "Power, P":"Tip: power is the rate of energy transfer, not the total energy transferred.",
      "Efficiency, η":"Misconception: efficiency cannot be greater than 100%.",
      "Accuracy":"Tip: accuracy is closeness to the true value.",
      "Precision":"Tip: precision is repeatability, not necessarily correctness.",
      "Systematic error":"Tip: repeated measurements do not remove systematic error.",
      "Uncertainty":"Tip: quote uncertainty with units, or as percentage uncertainty when comparing relative size.",
      "Terminal speed":"Tip: terminal speed happens when forces are balanced, so acceleration is zero.",
      "Archimedes' principle":"Tip: compare the object's weight with upthrust to predict sinking or floating.",
      "Elastic limit":"Tip: beyond this point, deformation becomes permanent.",
      "Spring constant, k":"Tip: larger k means a stiffer spring.",
      "Density":"Tip: density depends on both mass and volume.",
      "Energy":"Tip: energy is transferred or transformed, not used up.",
      "Dissipated or degraded energy":"Misconception: energy is not destroyed; it becomes less useful for doing work."
    };

    let filtered = [...flashcards];
    let index = 0;
    let known = new Set();

    const card = document.getElementById('card');
    const termEl = document.getElementById('term');
    const definitionEl = document.getElementById('definition');
    const tipEl = document.getElementById('tip');
    const searchEl = document.getElementById('search');
    const categoryEl = document.getElementById('category');
    const countPill = document.getElementById('countPill');
    const positionPill = document.getElementById('positionPill');
    const categoryPill = document.getElementById('categoryPill');
    const miniGrid = document.getElementById('miniGrid');

    function setupCategories() {
      const categories = ['All topics', ...Array.from(new Set(flashcards.map(c => c.category))).sort()];
      categoryEl.innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join('');
    }

    function render() {
      if (!filtered.length) {
        termEl.textContent = 'No cards found';
        definitionEl.textContent = 'Try changing your search or category filter.';
        tipEl.textContent = '';
        countPill.textContent = '0 cards';
        positionPill.textContent = 'No card selected';
        miniGrid.innerHTML = '';
        return;
      }

      index = Math.max(0, Math.min(index, filtered.length - 1));
      const current = filtered[index];
      card.classList.remove('flipped');
      termEl.textContent = current.term;
      definitionEl.textContent = current.definition;
      tipEl.textContent = extraTips[current.term] || 'Tip: say the definition aloud, then check whether you used the key scientific words.';
      countPill.textContent = `${filtered.length} cards`;
      positionPill.textContent = `Card ${index + 1} of ${filtered.length}`;
      categoryPill.textContent = categoryEl.value;
      renderMiniGrid();
    }

    function renderMiniGrid() {
      miniGrid.innerHTML = filtered.map((c, i) => `
        <button class="mini-card" onclick="jumpTo(${i})">
          <strong>${i + 1}. ${c.term}</strong>
          ${c.category}
        </button>
      `).join('');
    }

    function applyFilters() {
      const query = searchEl.value.trim().toLowerCase();
      const category = categoryEl.value;
      filtered = flashcards.filter(c => {
        const matchesQuery = !query || c.term.toLowerCase().includes(query) || c.definition.toLowerCase().includes(query);
        const matchesCategory = category === 'All topics' || c.category === category;
        return matchesQuery && matchesCategory;
      });
      index = 0;
      render();
    }

    function shuffleDeck() {
      for (let i = filtered.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [filtered[i], filtered[j]] = [filtered[j], filtered[i]];
      }
      index = 0;
      render();
    }

    function nextCard() {
      if (!filtered.length) return;
      index = (index + 1) % filtered.length;
      render();
    }

    function prevCard() {
      if (!filtered.length) return;
      index = (index - 1 + filtered.length) % filtered.length;
      render();
    }

    function jumpTo(i) {
      index = i;
      render();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function markKnown() {
      if (!filtered.length) return;
      known.add(filtered[index].term);
      document.getElementById('knowBtn').textContent = `Known: ${known.size}`;
      nextCard();
    }

    function resetProgress() {
      known.clear();
      document.getElementById('knowBtn').textContent = 'Mark as known';
      index = 0;
      render();
    }

    card.addEventListener('click', () => card.classList.toggle('flipped'));
    document.getElementById('flipBtn').addEventListener('click', () => card.classList.toggle('flipped'));
    document.getElementById('shuffleBtn').addEventListener('click', shuffleDeck);
    document.getElementById('nextBtn').addEventListener('click', nextCard);
    document.getElementById('prevBtn').addEventListener('click', prevCard);
    document.getElementById('knowBtn').addEventListener('click', markKnown);
    document.getElementById('resetBtn').addEventListener('click', resetProgress);
    searchEl.addEventListener('input', applyFilters);
    categoryEl.addEventListener('change', applyFilters);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') nextCard();
      if (e.key === 'ArrowLeft') prevCard();
      if (e.key === ' ') {
        e.preventDefault();
        card.classList.toggle('flipped');
      }
    });

    setupCategories();
    render();
  </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Physics Definition Flashcards</title>
  <style>
    :root {
      --bg: #0f0f12;
      --card: #191922;
      --card-2: #242432;
      --text: #f5f5f5;
      --muted: #b8b8c8;
      --accent: #8b3f91;
      --accent-light: #c875d0;
      --border: #343449;
      --success: #77d68a;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Helvetica, Arial, sans-serif;
      background: radial-gradient(circle at top, #232334 0%, var(--bg) 55%);
      color: var(--text);
      min-height: 100vh;
      padding: 24px;
    }

    .app {
      max-width: 980px;
      margin: 0 auto;
    }

    header {
      display: grid;
      gap: 10px;
      margin-bottom: 22px;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.4rem);
      letter-spacing: -0.05em;
      line-height: 0.95;
    }

    .subtitle {
      color: var(--muted);
      font-size: 1rem;
      max-width: 760px;
      line-height: 1.5;
    }

    .controls {
      display: grid;
      grid-template-columns: 1fr 220px;
      gap: 12px;
      margin: 18px 0 16px;
    }

    input, select, button {
      font: inherit;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: #12121a;
      color: var(--text);
      padding: 12px 14px;
      outline: none;
    }

    input:focus, select:focus {
      border-color: var(--accent-light);
      box-shadow: 0 0 0 3px rgba(200,117,208,0.15);
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 12px 0 22px;
    }

    button {
      cursor: pointer;
      background: var(--card-2);
      transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    }

    button:hover {
      transform: translateY(-1px);
      border-color: var(--accent-light);
      background: #2c2c3d;
    }

    button.primary {
      background: var(--accent);
      border-color: var(--accent-light);
      font-weight: 700;
    }

    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .pill {
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.04);
      padding: 8px 10px;
      border-radius: 999px;
    }

    .flashcard-wrap {
      perspective: 1200px;
      min-height: 360px;
    }

    .flashcard {
      width: 100%;
      min-height: 360px;
      border-radius: 28px;
      position: relative;
      transform-style: preserve-3d;
      transition: transform 0.55s ease;
      cursor: pointer;
    }

    .flashcard.flipped { transform: rotateY(180deg); }

    .face {
      position: absolute;
      inset: 0;
      padding: clamp(24px, 5vw, 48px);
      border-radius: 28px;
      background: linear-gradient(145deg, var(--card), #111119);
      border: 1px solid var(--border);
      box-shadow: 0 24px 80px rgba(0,0,0,0.35);
      backface-visibility: hidden;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 18px;
    }

    .back { transform: rotateY(180deg); }

    .tag {
      color: var(--accent-light);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.78rem;
    }

    .term {
      font-size: clamp(2.2rem, 7vw, 5rem);
      line-height: 0.95;
      letter-spacing: -0.06em;
      font-weight: 800;
    }

    .definition {
      font-size: clamp(1.35rem, 3vw, 2.15rem);
      line-height: 1.25;
      letter-spacing: -0.025em;
    }

    .extra {
      margin-top: 8px;
      color: var(--muted);
      line-height: 1.45;
      font-size: 1rem;
      border-left: 4px solid var(--accent);
      padding-left: 14px;
    }

    .nav {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 16px;
    }

    .list {
      margin-top: 28px;
      display: grid;
      gap: 10px;
    }

    details {
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 12px 14px;
    }

    summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--accent-light);
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 8px;
      margin-top: 12px;
    }

    .mini-card {
      background: #111119;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 10px;
      font-size: 0.9rem;
      color: var(--muted);
    }

    .mini-card strong {
      display: block;
      color: var(--text);
      margin-bottom: 4px;
    }

    @media (max-width: 700px) {
      body { padding: 14px; }
      .controls { grid-template-columns: 1fr; }
      .nav { grid-template-columns: 1fr; }
      .flashcard, .flashcard-wrap { min-height: 430px; }
    }
  </style>
</head>
<body>
  <main class="app">
    <header>
      <h1>Physics Definition Flashcards</h1>
      <p class="subtitle">Click the card to reveal the definition. Use search or topic filters to revise a smaller set. Each term from multi-definition images is separated into its own card.</p>
    </header>

    <section class="controls">
      <input id="search" type="search" placeholder="Search term or definition..." />
      <select id="category"></select>
    </section>

    <section class="button-row">
      <button class="primary" id="shuffleBtn">Shuffle deck</button>
      <button id="flipBtn">Flip card</button>
      <button id="resetBtn">Reset progress</button>
    </section>

    <section class="stats">
      <span class="pill" id="countPill">0 cards</span>
      <span class="pill" id="positionPill">Card 1 of 1</span>
      <span class="pill" id="categoryPill">All topics</span>
    </section>

    <section class="flashcard-wrap" aria-live="polite">
      <article class="flashcard" id="card">
        <div class="face front">
          <div class="tag" id="frontTag">Term</div>
          <div class="term" id="term">Loading...</div>
          <div class="extra">Click to reveal the definition.</div>
        </div>
        <div class="face back">
          <div class="tag" id="backTag">Definition</div>
          <div class="definition" id="definition">Loading...</div>
          <div class="extra" id="tip"></div>
        </div>
      </article>
    </section>

    <nav class="nav">
      <button id="prevBtn">Previous</button>
      <button id="knowBtn">Mark as known</button>
      <button id="nextBtn">Next</button>
    </nav>

    <section class="list">
      <details>
        <summary>Show all cards in current filtered deck</summary>
        <div class="mini-grid" id="miniGrid"></div>
      </details>
    </section>
  </main>

  <script>
    const flashcards = [
      // Kinematics and measurement
      {term:"Kinematics", definition:"Study of motion.", category:"Kinematics"},
      {term:"Classical physics", definition:"Physics theories that pre-dated the paradigm shifts introduced by quantum physics and relativity.", category:"General physics"},
      {term:"Uniform", definition:"Unchanging.", category:"General physics"},
      {term:"Magnitude", definition:"Size.", category:"General physics"},
      {term:"Scalars", definition:"Quantities that have only magnitude and no direction.", category:"Vectors"},
      {term:"Vector", definition:"A quantity that has both magnitude and direction.", category:"Vectors"},
      {term:"Distance", definition:"Total length travelled, without consideration of direction.", category:"Kinematics"},
      {term:"Displacement, linear", definition:"Distance in a straight line from a fixed reference point in a specified direction.", category:"Kinematics"},
      {term:"Metre, m", definition:"SI unit of length; a fundamental unit.", category:"Units"},
      {term:"Speed, v", definition:"Average speed is distance travelled divided by time taken. Instantaneous speed is determined over a very short time interval during which speed is assumed not to change.", category:"Kinematics"},
      {term:"Reaction time", definition:"The time delay between an event occurring and a response, for example the delay when using a stopwatch.", category:"Measurement"},
      {term:"Sensor", definition:"An electrical component that responds to a change in a physical property with a corresponding change in an electrical property, usually resistance. Also called a transducer.", category:"Measurement"},
      {term:"Light gate", definition:"Electronic sensor used to detect motion when an object interrupts a beam of light.", category:"Measurement"},
      {term:"Second, s", definition:"SI unit of time; a fundamental unit.", category:"Units"},
      {term:"At rest", definition:"Stays stationary in the same position.", category:"Kinematics"},
      {term:"Milky Way", definition:"The galaxy in which our Solar System is located.", category:"Astronomy"},
      {term:"Velocity, v", definition:"Rate of change of position.", category:"Kinematics"},
      {term:"Orbit", definition:"The curved path, which may be circular, of a mass around a larger central mass.", category:"Astronomy"},
      {term:"Tangent", definition:"Line which touches a given curve at a single point.", category:"Graphs and maths"},
      {term:"Acceleration, a", definition:"Rate of change of velocity with time. Acceleration is a vector quantity.", category:"Kinematics"},
      {term:"Deceleration", definition:"Term commonly used to describe a decreasing speed.", category:"Kinematics"},
      {term:"Linear relationship", definition:"One which produces a straight-line graph.", category:"Graphs and maths"},
      {term:"Gradient", definition:"The rate at which one physical quantity changes in response to changes in another physical quantity. For a y-x graph, gradient = Δy / Δx.", category:"Graphs and maths"},
      {term:"Integration", definition:"Mathematical process used to determine the area under a graph.", category:"Graphs and maths"},
      {term:"Spreadsheet", definition:"Electronic document in which data is arranged in rows and columns of a grid, and can be manipulated and used in calculations.", category:"Data handling"},
      {term:"Calculus", definition:"Branch of mathematics which deals with continuous change.", category:"Graphs and maths"},
      {term:"Differentiate", definition:"Mathematically determine an equation for a rate of change.", category:"Graphs and maths"},
      {term:"Equations of motion", definition:"Equations that can be used to make calculations about objects moving with uniform acceleration.", category:"Kinematics"},
      {term:"Air resistance", definition:"Resistive force opposing the motion of an object through air. A type of drag force.", category:"Forces"},
      {term:"Acceleration due to gravity, g", definition:"Acceleration of a mass falling freely towards Earth. Near Earth's surface, g = 9.8 m s⁻², often approximated as 10 m s⁻². Also called acceleration of free fall.", category:"Forces"},
      {term:"Free fall", definition:"Motion through the air under the effects of gravity but without air resistance.", category:"Forces"},
      {term:"Negligible", definition:"Too small to be significant.", category:"General physics"},
      {term:"Projectile", definition:"An object projected through the air which then moves only under the action of gravity and air resistance.", category:"Projectiles"},
      {term:"Resolve a vector", definition:"To express a single vector as components, usually two components that are perpendicular to each other.", category:"Vectors"},
      {term:"Stroboscope", definition:"Apparatus used for observing rapid motions. It produces regular flashes of light at an appropriate frequency chosen by the user.", category:"Measurement"},
      {term:"Trajectory", definition:"Path followed by a projectile.", category:"Projectiles"},
      {term:"Parabolic", definition:"In the shape of a parabola. The trajectory of a projectile is parabolic in a gravitational field if air resistance is negligible.", category:"Projectiles"},
      {term:"Range of a projectile", definition:"Horizontal distance travelled before impact with the ground.", category:"Projectiles"},
      {term:"Impact", definition:"Collision involving relatively large forces over a short time.", category:"Momentum"},
      {term:"Imagination", definition:"Formation of new ideas that are not related to direct sense perception or experimental results.", category:"Nature of science"},
      {term:"Intuition", definition:"Immediate understanding, without reasoning.", category:"Nature of science"},
      {term:"Inspiration", definition:"Stimulation, usually to be creative.", category:"Nature of science"},

      // Fluids, drag, forces, fields
      {term:"Drag", definition:"Force or forces opposing motion through a fluid; sometimes called fluid resistance.", category:"Fluids"},
      {term:"Fluid", definition:"Liquid or gas.", category:"Fluids"},
      {term:"Fluid resistance", definition:"Force or forces opposing motion through a fluid; sometimes called drag.", category:"Fluids"},
      {term:"Terminal speed", definition:"The greatest downward speed of a falling object experiencing resistive forces such as air resistance. It occurs when the object's weight is equal to the sum of the resistive forces plus upthrust.", category:"Fluids"},
      {term:"Video analysis", definition:"Analysis of motion by freeze-frame or slow-motion video replay.", category:"Measurement"},
      {term:"Thought experiment", definition:"An experiment carried out in the mind rather than actually being done, normally because it is otherwise impossible.", category:"Nature of science"},
      {term:"Interaction", definition:"Any event in which two or more objects exert forces on each other.", category:"Forces"},
      {term:"Newton, N", definition:"Derived SI unit of force. 1 N = 1 kg m s⁻².", category:"Units"},
      {term:"Mass", definition:"A measure of an object's resistance to a change of motion, or inertia.", category:"Forces"},
      {term:"Kilogramme, kg", definition:"SI unit of mass; a fundamental unit.", category:"Units"},
      {term:"Weight, Fg", definition:"Gravitational force acting on a mass. Fg = mg.", category:"Forces"},
      {term:"Gravitational field strength, g", definition:"The gravitational force per unit mass that would be experienced by a small test mass placed at that point. g = Fg / m. SI unit: N kg⁻¹. Numerically equal to the acceleration due to gravity.", category:"Forces"},
      {term:"Centre of mass", definition:"Average position of all the mass of an object. The mass is distributed evenly either side of any plane through its centre of mass.", category:"Forces"},
      {term:"Force meter", definition:"Instrument used to measure forces. Also sometimes called a newton meter or spring balance.", category:"Measurement"},
      {term:"Calibrate", definition:"Put numbered divisions on a scale.", category:"Measurement"},
      {term:"Weigh", definition:"Determine the weight of an object. In everyday use, 'weighing' usually means quoting the result as the equivalent mass.", category:"Measurement"},
      {term:"Peer review", definition:"Evaluation of scientific work by experts in the same field of study.", category:"Nature of science"},
      {term:"Tension", definition:"Force that tries to stretch an object or material.", category:"Forces"},
      {term:"Compression", definition:"Force that tries to squash an object or material.", category:"Forces"},
      {term:"Deformation", definition:"Change of shape.", category:"Materials"},
      {term:"Normal", definition:"Perpendicular to a surface.", category:"Forces"},
      {term:"Buoyancy force", definition:"Vertical upward force on an object placed in or on a fluid. Sometimes called upthrust.", category:"Fluids"},
      {term:"Density", definition:"Mass divided by volume.", category:"Fluids"},
      {term:"Archimedes' principle", definition:"When an object is wholly or partially immersed in a fluid, it experiences a buoyancy force equal to the weight of the fluid displaced.", category:"Fluids"},
      {term:"Elastic behaviour", definition:"A material regains its original shape after a force causing deformation has been removed.", category:"Materials"},
      {term:"Elastic limit", definition:"The maximum force and/or extension that a material or spring can sustain before it becomes permanently deformed.", category:"Materials"},
      {term:"Extension", definition:"Displacement of the end of an object that is being stretched.", category:"Materials"},
      {term:"Spring constant, k", definition:"The constant in Hooke's law that represents the stiffness of a spring or other material.", category:"Materials"},
      {term:"Restoring force", definition:"Force acting in the opposite direction to displacement, returning an object to its equilibrium position.", category:"Materials"},
      {term:"Interpolate", definition:"Estimate a value within a known data range.", category:"Graphs and maths"},
      {term:"Extrapolate", definition:"Predict behaviour outside the range of available data.", category:"Graphs and maths"},
      {term:"Friction", definition:"Resistive forces opposing relative motion. Occurs between solid surfaces, but also with fluids. Static friction prevents movement, whereas dynamic friction occurs when there is already motion.", category:"Forces"},
      {term:"Coefficient of friction, μ", definition:"Constant used to represent the amount of friction between two different surfaces. It may be static or dynamic.", category:"Forces"},
      {term:"Constant", definition:"A number assumed to have the same numerical value under a specified range of circumstances.", category:"General physics"},
      {term:"Fundamental constants", definition:"Numbers assumed to have exactly the same numerical values under all circumstances and all times.", category:"General physics"},
      {term:"Coefficient", definition:"A multiplying constant placed before a variable, indicating a physical property.", category:"General physics"},
      {term:"Viscosity", definition:"Resistance of a fluid to movement.", category:"Fluids"},
      {term:"Viscous drag", definition:"The drag force acting on a moving object due to the viscosity of the fluid through which it is moving.", category:"Fluids"},
      {term:"Turbulence", definition:"Flow of a fluid which is erratic and unpredictable.", category:"Fluids"},
      {term:"Stokes' law", definition:"Equation for the viscous drag acting on a smooth, spherical object undergoing non-turbulent motion.", category:"Fluids"},
      {term:"Streamlined", definition:"Having a shape that reduces the drag forces acting on an object moving through a fluid.", category:"Fluids"},
      {term:"Field", definition:"A region of space in which a mass, charge, or current experiences a force due to the presence of one or more other masses, charges, or currents.", category:"Fields"},
      {term:"Free-body diagram", definition:"Diagram showing all the forces acting on a single object, and no other forces.", category:"Forces"},
      {term:"Point particle, mass or charge", definition:"Theoretical concept used to simplify the discussion of forces acting on objects, especially in gravitational and electric fields.", category:"Fields"},
      {term:"Resultant force", definition:"The vector sum of the forces acting on an object, sometimes called the unbalanced or net force.", category:"Forces"},
      {term:"Resultant", definition:"The single vector that has the same effect as the combination of two or more separate vectors.", category:"Vectors"},
      {term:"Components of a vector", definition:"Any single vector can be considered as having the same effect as two parts, or components, perpendicular to each other.", category:"Vectors"},
      {term:"Inclined plane", definition:"Flat surface at an angle to the horizontal, but not perpendicular. A simple device that can reduce the force needed to raise a load; sometimes called a ramp.", category:"Forces"},
      {term:"Newton's laws of motion", definition:"First law: an object remains at rest or continues in a straight line at constant speed unless a resultant force acts on it. Second law: acceleration is proportional to resultant force. Third law: when one body exerts a force on another, the second body exerts an equal and opposite force on the first.", category:"Forces"},
      {term:"Balanced forces", definition:"If an object is in mechanical equilibrium, the forces acting on it are described as balanced.", category:"Forces"},
      {term:"Equilibrium", definition:"An object is in equilibrium if it is unchanging under the action of two or more influences such as forces. Types include translational, rotational and thermal equilibrium.", category:"Forces"},
      {term:"Translational", definition:"Changing position.", category:"Forces"},
      {term:"Proportional relationship", definition:"Two variables are directly proportional if they always have the same ratio.", category:"Graphs and maths"},
      {term:"Uncertainty bars", definition:"Vertical and horizontal lines drawn through data points on a graph to represent the uncertainties in the two values.", category:"Measurement"},
      {term:"Inertia", definition:"Resistance to a change of motion. Depends on the mass of the object.", category:"Forces"},
      {term:"Momentum, p", definition:"Mass times velocity; a vector quantity.", category:"Momentum"},
      {term:"System", definition:"The object or objects being considered, and nothing else. An isolated system is a system into which matter and energy cannot flow in or out.", category:"General physics"},
      {term:"Surroundings", definition:"Everything apart from the system that is being considered; similar to the environment.", category:"General physics"},
      {term:"Scientific notation", definition:"Every number is expressed in the form a × 10^b, where a is a decimal number larger than 1 and less than 10, and b is an integer exponent.", category:"Measurement"},
      {term:"Significant figures", definition:"All the digits used in data to carry meaning, whether they are before or after a decimal point.", category:"Measurement"},
      {term:"Collision", definition:"Two or more objects coming together and exerting forces on each other for a relatively short time.", category:"Momentum"},
      {term:"Explosion", definition:"Term used in physics to describe when two or more masses, initially at rest, are propelled apart from each other.", category:"Momentum"},

      {term:"Propel", definition:"Provide a force for an intended motion.", category:"Momentum"},
      {term:"Jet engine", definition:"An engine that achieves propulsion by emitting a fast-moving stream of gas or liquid in the opposite direction from the intended motion.", category:"Momentum"},
      {term:"Rocket engine", definition:"Similar to a jet engine, but there is no air intake. Instead, an oxidant is carried on the vehicle together with the fuel.", category:"Momentum"},
      {term:"Impulse", definition:"The product of force and the time for which the force acts.", category:"Momentum"},
      {term:"Centripetal force", definition:"The name given to any force which results in motion along a circular path.", category:"Circular motion"},
      {term:"Banked track", definition:"A sloping surface to enable faster motion around curves.", category:"Circular motion"},
      {term:"Centripetal acceleration", definition:"The constantly changing velocity of an object moving along a circular path is equivalent to an acceleration towards the centre of the circle.", category:"Circular motion"},
      {term:"Radians", definition:"Unit of measurement of angle. There are 2π radians in 360°.", category:"Circular motion"},
      {term:"Time period, T", definition:"The duration of an event that occurs regularly. T = 1/f.", category:"Circular motion"},
      {term:"Frequency, f", definition:"The number of repeating events per unit time.", category:"Circular motion"},
      {term:"Hertz, Hz", definition:"Derived SI unit of frequency. 1 Hz = one event per second.", category:"Units"},
      {term:"Angular velocity, ω", definition:"Change of angle divided by change of time. Sometimes called angular speed.", category:"Circular motion"},

      // Work, energy, power, uncertainty, rotation
      {term:"Work, W", definition:"The energy transfer that occurs when an object is moved with a force. More precisely, work done = force × displacement in the direction of the force.", category:"Energy"},
      {term:"Energy", definition:"Ability to do work.", category:"Energy"},
      {term:"Joule, J", definition:"Derived SI unit of work and energy. 1 J = 1 N m.", category:"Units"},
      {term:"Abstract concept", definition:"An idea which has no physical form.", category:"General physics"},
      {term:"Subjective", definition:"Describes an opinion based on personal experiences and emotions. Compare with objective, meaning free from emotion and bias.", category:"Nature of science"},
